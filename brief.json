    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tableau de Bord de Suivi des Dépenses Locatives (Locataires) | Calculateur de Budget Locatif</title>\n    <meta name=\"description\" content=\"Permet aux locataires de suivre et visualiser leurs dépenses de loyer, charges et autres frais liés à leur logement en France.\">\n    <style>\n        :root {\n            --slate-bg: #f8f9fa;\n            --slate-panel: #ffffff;\n            --slate-text: #343a40;\n            --slate-border: #e9ecef;\n            --slate-accent: #007bff;\n            --slate-shadow: rgba(0, 0, 0, 0.05);\n            --font-family-display: 'Montserrat', sans-serif;\n            --font-family-ui: 'Inter', sans-serif;\n        }\n\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Montserrat:wght@700&display=swap');\n\n        body {\n            font-family: var(--font-family-ui);\n            line-height: 1.6;\n            color: var(--slate-text);\n            background-color: var(--slate-bg);\n            margin: 0;\n            padding: 20px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        h1, h2, h3 {\n            font-family: var(--font-family-display);\n            color: var(--slate-text);\n            margin-top: 0;\n        }\n\n        h1 {\n            font-size: 2.5em;\n            text-align: center;\n            margin-bottom: 20px;\n        }\n\n        h2 {\n            font-size: 1.8em;\n            margin-bottom: 15px;\n            border-bottom: 2px solid var(--slate-border);\n            padding-bottom: 5px;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1200px;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 20px;\n            margin-bottom: 30px;\n        }\n\n        .panel {\n            background-color: var(--slate-panel);\n            border: 1px solid var(--slate-border);\n            border-radius: 8px;\n            box-shadow: 0 4px 6px var(--slate-shadow);\n            padding: 20px;\n            position: relative;\n        }\n\n        .panel-full {\n            grid-column: 1 / -1;\n        }\n\n        label {\n            display: block;\n            margin-bottom: 8px;\n            font-weight: 600;\n            font-size: 0.9em;\n            color: var(--slate-text);\n        }\n\n        input[type=\"number\"],\n        select,\n        textarea {\n            width: calc(100% - 20px);\n            padding: 10px;\n            margin-bottom: 15px;\n            border: 1px solid var(--slate-border);\n            border-radius: 4px;\n            box-sizing: border-box;\n            font-family: var(--font-family-ui);\n            font-size: 1em;\n            color: var(--slate-text);\n        }\n\n        input[type=\"number\"]:focus,\n        select:focus,\n        textarea:focus {\n            outline: none;\n            border-color: var(--slate-accent);\n            box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.25);\n        }\n\n        button {\n            background-color: var(--slate-accent);\n            color: white;\n            padding: 12px 20px;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 1em;\n            font-weight: 600;\n            transition: background-color 0.2s ease;\n        }\n\n        button:hover {\n            background-color: #0056b3;\n        }\n\n        .result-area {\n            background-color: var(--slate-panel);\n            border: 1px solid var(--slate-border);\n            border-radius: 8px;\n            box-shadow: 0 4px 6px var(--slate-shadow);\n            padding: 20px;\n            margin-top: 20px;\n            display: none; /* Hidden by default */\n            grid-column: 1 / -1;\n        }\n\n        .result-area h3 {\n            color: var(--slate-accent);\n            margin-bottom: 15px;\n        }\n\n        .metric-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));\n            gap: 15px;\n            margin-top: 20px;\n        }\n\n        .metric-card {\n            background-color: var(--slate-bg);\n            border: 1px solid var(--slate-border);\n            border-radius: 6px;\n            padding: 15px;\n            text-align: center;\n        }\n\n        .metric-card .value {\n            font-family: var(--font-family-display);\n            font-size: 2em;\n            font-weight: 700;\n            color: var(--slate-accent);\n            margin-bottom: 5px;\n            line-height: 1.2;\n        }\n\n        .metric-card .label {\n            font-size: 0.85em;\n            color: var(--slate-text);\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n\n        table th, table td {\n            border: 1px solid var(--slate-border);\n            padding: 10px;\n            text-align: left;\n        }\n\n        table th {\n            background-color: var(--slate-bg);\n            font-weight: 600;\n            text-transform: uppercase;\n            font-size: 0.9em;\n        }\n\n        table tr:nth-child(even) {\n            background-color: #f2f2f2;\n        }\n\n        .seo-section {\n            width: 100%;\n            max-width: 1200px;\n            margin-top: 40px;\n            padding: 20px;\n            background-color: var(--slate-panel);\n            border: 1px solid var(--slate-border);\n            border-radius: 8px;\n            box-shadow: 0 4px 6px var(--slate-shadow);\n        }\n\n        .seo-section h2 {\n            text-align: center;\n        }\n\n        .seo-section p {\n            margin-bottom: 1em;\n        }\n\n        .seo-section ul {\n            list-style-type: disc;\n            margin-left: 20px;\n            margin-bottom: 1em;\n        }\n\n        .seo-section li {\n            margin-bottom: 0.5em;\n        }\n\n        @media (max-width: 768px) {\n            .container {\n                grid-template-columns: 1fr;\n            }\n            h1 {\n                font-size: 2em;\n            }\n            .metric-grid {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://tableau-de-bord-de-suivi-des-depenses-locatives-268a12c7.onrender.com\">\n    <meta property=\"og:title\" content=\"Tableau de Bord de Suivi des Dépenses Locatives (Locataires)\">\n    <meta property=\"og:description\" content=\"Permet aux locataires de suivre et visualiser leurs dépenses de loyer, charges et autres frais liés à leur logement en France.\">\n    <meta property=\"og:url\" content=\"https://tableau-de-bord-de-suivi-des-depenses-locatives-268a12c7.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Tableau de Bord de Suivi des Dépenses Locatives (Locataires)\", \"description\": \"Permet aux locataires de suivre et visualiser leurs dépenses de loyer, charges et autres frais liés à leur logement en France.\", \"url\": \"https://tableau-de-bord-de-suivi-des-depenses-locatives-268a12c7.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"tableau-de-bord-de-suivi-des-depenses-locatives-268a12c7\" data-runtime-mode=\"analysis_tool\">\n    <h1>Tableau de Bord de Suivi des Dépenses Locatives</h1>\n\n    <div class=\"container\">\n        <div class=\"panel panel-full\">\n            <h2>Calculateur de Budget Locatif</h2>\n            <p>Saisissez vos informations pour obtenir une vue d'ensemble de vos dépenses mensuelles.</p>\n            <form id=\"tool-form\">\n                <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px;\">\n                    <div>\n                        <label for=\"loyer\">Loyer mensuel hors charges (€):</label>\n                        <input type=\"number\" id=\"loyer\" name=\"loyer\" value=\"650\" min=\"0\" required>\n                    </div>\n                    <div>\n                        <label for=\"chargesForfaitaires\">Charges forfaitaires mensuelles (€) (si applicables):</label>\n                        <input type=\"number\" id=\"chargesForfaitaires\" name=\"chargesForfaitaires\" value=\"100\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"regularisationCharges\">Provision sur charges mensuelles (€) (si applicables):</label>\n                        <input type=\"number\" id=\"regularisationCharges\" name=\"regularisationCharges\" value=\"80\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"electricite\">Électricité mensuelle (€) (estimation):</label>\n                        <input type=\"number\" id=\"electricite\" name=\"electricite\" value=\"50\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"gaz\">Gaz mensuel (€) (estimation):</label>\n                        <input type=\"number\" id=\"gaz\" name=\"gaz\" value=\"30\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"eau\">Eau mensuelle (€) (estimation):</label>\n                        <input type=\"number\" id=\"eau\" name=\"eau\" value=\"20\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"internet\">Internet/Téléphonie mensuel (€):</label>\n                        <input type=\"number\" id=\"internet\" name=\"internet\" value=\"35\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"assuranceHabitation\">Assurance habitation mensuelle (€):</label>\n                        <input type=\"number\" id=\"assuranceHabitation\" name=\"assuranceHabitation\" value=\"15\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"taxeHabitationMensuelle\">Taxe d'habitation mensuelle (€) (estimation, si applicable):</label>\n                        <input type=\"number\" id=\"taxeHabitationMensuelle\" name=\"taxeHabitationMensuelle\" value=\"10\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"fraisMaintenance\">Frais de maintenance/petits travaux mensuels (€) (estimation):</label>\n                        <input type=\"number\" id=\"fraisMaintenance\" name=\"fraisMaintenance\" value=\"10\" min=\"0\">\n                    </div>\n                    <div>\n                        <label for=\"autresFrais\">Autres frais récurrents mensuels (€) (Ex: parking, femme de ménage):</label>\n                        <input type=\"number\" id=\"autresFrais\" name=\"autresFrais\" value=\"0\" min=\"0\">\n                    </div>\n                </div>\n                <button type=\"submit\" id=\"tool-submit\" style=\"margin-top: 20px;\">Calculer mon Budget Locatif</button>\n            </form>\n        </div>\n\n        <div id=\"tool-result\" class=\"result-area\">\n            <h3 id=\"result-headline\">Votre Bilan Locatif Mensuel</h3>\n            <div class=\"metric-grid\">\n                <div class=\"metric-card\">\n                    <div class=\"value\" id=\"totalLoyerCharges\">0.00€</div>\n                    <div class=\"label\">Loyer & Charges (Minimum)</div>\n                </div>\n                <div class=\"metric-card\">\n                    <div class=\"value\" id=\"totalDepensesFixes\">0.00€</div>\n                    <div class=\"label\">Total Dépenses Fixes</div>\n                </div>\n                <div class=\"metric-card\">\n                    <div class=\"value\" id=\"budgetTotalEstime\">0.00€</div>\n                    <div class=\"label\">Budget Total Estimé</div>\n                </div>\n            </div>\n\n            <h4>Détail des Dépenses</h4>\n            <table id=\"depensesTable\">\n                <thead>\n                    <tr>\n                        <th>Catégorie</th>\n                        <th>Montant Mensuel (€)</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <!-- Results will be injected here -->\n                </tbody>\n            </table>\n\n            <p style=\"margin-top: 20px; font-size: 0.9em;\">\n                <em>Ces calculs sont des estimations. Les montants réels peuvent varier en fonction de votre consommation et des ajustements de charges. Il est conseillé de consulter vos contrats et factures.</em>\n            </p>\n\n            <div style=\"margin-top: 25px; text-align: center;\">\n                <button data-affiliate-slot=\"budget_conseils_personnalises\">Obtenir des Conseils Personnalisés</button>\n                <button data-affiliate-slot=\"comparer_assurances_habitation\" style=\"margin-left: 15px;\">Comparer les Assurances Habitation</button>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"seo-section\">\n        <h2>Optimiser Votre Budget Locatif en France : Le Guide Complet</h2>\n        <p>Gérer son budget quand on est locataire en France peut s'avérer complexe. Entre le loyer, les charges, l'électricité, le gaz, l'eau, l'assurance habitation et parfois la taxe d'habitation, les dépenses s'accumulent vite. Notre outil de suivi des dépenses locatives est conçu pour vous offrir une vision claire et détaillée de vos engagements financiers mensuels.</p>\n\n        <h3>Pourquoi un outil de gestion budgétaire pour locataires ?</h3>\n        <p>Un suivi rigoureux est essentiel pour éviter les mauvaises surprises et optimiser vos économies. Que vous soyez un jeune actif, une famille ou un étudiant, anticiper vos dépenses locatives vous permet de mieux planifier votre budget global. Notre calculateur prend en compte toutes les variables clés pour une estimation précise de votre coût de logement en France.</p>\n\n        <h3>Comprendre les dépenses clés de votre logement</h3>\n        <ul>\n            <li><strong>Loyer et Charges Locatives :</strong> La base de vos dépenses. Les charges peuvent être forfaitaires ou soumises à régularisation annuelle. Notre outil vous aide à différencier ces montants.</li>\n            <li><strong>Consommations Énergétiques :</strong> Électricité et gaz sont des postes importants. Estimez vos coûts pour anticiper.</li>\n            <li><strong>Eau :</strong> Souvent incluse dans les charges ou facturée séparément, ne la négligez pas.</li>\n            <li><strong>Assurance Habitation :</strong> Obligatoire pour les locataires, son coût varie.</li>\n            <li><strong>Internet et Téléphonie :</strong> Un service essentiel dont le coût doit être intégré à votre budget.</li>\n            <li><strong>Taxe d'Habitation :</strong> Même si elle a évolué, certains locataires peuvent encore être concernés par un résiduel ou la taxe d'enlèvement des ordures ménagères.</li>\n            <li><strong>Autres Frais :</strong> Petit entretien, parking, services... tout compte !</li>\n        </ul>\n\n        <h3>Comment notre tableau de bord locatif vous aide ?</h3>\n        <p>En renseignant simplement les champs, vous obtenez instantanément un bilan précis de vos dépenses mensuelles. Visualisez votre budget total estimé, le minimum à prévoir pour le loyer et les charges, et le détail par catégorie. Cet outil est parfait pour :</p>\n        <ul>\n            <li>Établir un budget prévisionnel avant un emménagement.</li>\n            <li>Suivre vos dépenses au fil des mois et identifier les postes où économiser.</li>\n            <li>Préparer une demande de location en ayant une visibilité sur vos capacités financières.</li>\n            <li>Mieux comprendre la composition de votre budget logement.</li>\n        </ul>\n        <p>Ne laissez plus vos dépenses locatives vous prendre au dépourvu. Utilisez notre outil gratuit pour une gestion saine et sereine de votre budget de locataire en France.</p>\n    </div>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const loyer = parseFloat(document.getElementById('loyer').value) || 0;\n            const chargesForfaitaires = parseFloat(document.getElementById('chargesForfaitaires').value) || 0;\n            const regularisationCharges = parseFloat(document.getElementById('regularisationCharges').value) || 0;\n            const electricite = parseFloat(document.getElementById('electricite').value) || 0;\n            const gaz = parseFloat(document.getElementById('gaz').value) || 0;\n            const eau = parseFloat(document.getElementById('eau').value) || 0;\n            const internet = parseFloat(document.getElementById('internet').value) || 0;\n            const assuranceHabitation = parseFloat(document.getElementById('assuranceHabitation').value) || 0;\n            const taxeHabitationMensuelle = parseFloat(document.getElementById('taxeHabitationMensuelle').value) || 0;\n            const fraisMaintenance = parseFloat(document.getElementById('fraisMaintenance').value) || 0;\n            const autresFrais = parseFloat(document.getElementById('autresFrais').value) || 0;\n\n            const totalLoyerCharges = loyer + chargesForfaitaires + regularisationCharges;\n            const totalDepensesFixes = electricite + gaz + eau + internet + assuranceHabitation + taxeHabitationMensuelle + fraisMaintenance + autresFrais;\n            const budgetTotalEstime = totalLoyerCharges + totalDepensesFixes;\n\n            document.getElementById('totalLoyerCharges').textContent = totalLoyerCharges.toFixed(2) + '€';\n            document.getElementById('totalDepensesFixes').textContent = totalDepensesFixes.toFixed(2) + '€';\n            document.getElementById('budgetTotalEstime').textContent = budgetTotalEstime.toFixed(2) + '€';\n\n            const depenses = [\n                { categorie: \"Loyer (hors charges)\", montant: loyer },\n                { categorie: \"Charges Forfaitaires\", montant: chargesForfaitaires },\n                { categorie: \"Provision sur Charges\", montant: regularisationCharges },\n                { categorie: \"Électricité\", montant: electricite },\n                { categorie: \"Gaz\", montant: gaz },\n                { categorie: \"Eau\", montant: eau },\n                { categorie: \"Internet/Téléphonie\", montant: internet },\n                { categorie: \"Assurance Habitation\", montant: assuranceHabitation },\n                { categorie: \"Taxe d'Habitation (estimation mensuelle)\", montant: taxeHabitationMensuelle },\n                { categorie: \"Frais de Maintenance (estimation mensuelle)\", montant: fraisMaintenance },\n                { categorie: \"Autres Frais Récurrents\", montant: autresFrais }\n            ];\n\n            const tableBody = document.querySelector('#depensesTable tbody');\n            tableBody.innerHTML = ''; // Clear previous results\n\n            depenses.forEach(item => {\n                if (item.montant > 0) {\n                    const row = tableBody.insertRow();\n                    const cell1 = row.insertCell(0);\n                    const cell2 = row.insertCell(1);\n                    cell1.textContent = item.categorie;\n                    cell2.textContent = item.montant.toFixed(2) + '€';\n                }\n            });\n\n            documen